{
  "name": "self-correcting-agent",
  "displayName": "Self-Correcting Code Agent",
  "description": "AI code generation with drift detection and self-correction using Gemini + Groq",
  "version": "1.0.0",
  "publisher": "genai-team",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning"
  ],
  "activationEvents": [
    "onCommand:self-correcting-agent.generate"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "self-correcting-agent.generate",
        "title": "Generate Code with Self-Correction",
        "category": "AI Agent"
      }
    ],
    "keybindings": [
      {
        "command": "self-correcting-agent.generate",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Self-Correcting Agent",
      "properties": {
        "selfCorrectingAgent.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the FastAPI backend server"
        },
        "selfCorrectingAgent.maxSteps": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of generation steps"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
